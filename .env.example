# ============================================
# Job Aggregator - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/job-portal
# If using with existing MERN app, use the same URI

# Server Config (if running standalone)
PORT=5001
NODE_ENV=development

# ============================================
# API Keys (Register for free accounts)
# ============================================

# Adzuna API - https://developer.adzuna.com/
# Free: 250 requests/day
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key
ADZUNA_COUNTRY=in

# JSearch (RapidAPI) - https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
# Free: 500 requests/month
JSEARCH_API_KEY=your_rapidapi_key

# ============================================
# Scraper Settings
# ============================================
SCRAPER_CONCURRENCY=3
SCRAPER_REQUEST_DELAY_MS=1000
SCRAPER_MAX_PAGES_PER_SOURCE=5
SCRAPER_JOBS_PER_PAGE=50

# ============================================
# Scheduler Settings
# ============================================
# Full sync every 6 hours
SYNC_CRON_FULL=0 */6 * * *
# Cleanup expired jobs daily at 2 AM
SYNC_CRON_CLEANUP=0 2 * * *
# Stats update every hour
SYNC_CRON_STATS=0 * * * *

# ============================================
# Rate Limiting
# ============================================
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=100

# ============================================
# Logging
# ============================================
LOG_LEVEL=info
LOG_FILE=logs/job-aggregator.log
